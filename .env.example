# Environment
# Must always set to production in production
# @see {@link https://www.youtube.com/watch?v=HMM7GJC5E2o}
NODE_ENV=production

# Database (SQLite file path)
DATABASE_URL="./data/app.db"

# Server
PORT=3000

# Security
RATE_LIMIT_MAX=100 # 4 is for tests, increase if you need more
CORS_ORIGINS=http://localhost:3000,https://example.com # Comma-separated list

# JWT
JWT_SECRET= # required
JWT_EXPIRES_IN=7d
COOKIE_NAME=session_id
