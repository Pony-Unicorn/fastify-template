{
  "name": "fastify-template",
  "version": "1.0.1",
  "description": "A modern Fastify TypeScript backend template with TypeBox validation, Drizzle ORM, built-in security plugins, and RESTful API design following GitHub API conventions.",
  "main": "app.ts",
  "type": "module",
  "directories": {
    "test": "test"
  },
  "scripts": {
    "start": "node dist/server.js",
    "build": "tsc",
    "watch": "tsc -w",
    "dev": "tsx --env-file=.env ./src/server.ts",
    "test": "pnpm run db:seed && c8 pnpm run test:run",
    "test:run": "glob -c \"tsx --test\" \"./test/**/*.ts\"",
    "lint": "eslint --ignore-pattern=dist",
    "lint:fix": "pnpm run lint -- --fix",
    "format": "prettier . --list-different",
    "format-fix": "prettier . --write",
    "util:hash": "tsx ./scripts/hash-password.ts",
    "db:create": "tsx --env-file=.env ./scripts/create-database.ts",
    "db:seed": "tsx --env-file=.env ./scripts/seed-database.ts",
    "db:types": "kysely-codegen --dialect sqlite --env-file .env"
  },
  "keywords": [
    "fastify",
    "typescript",
    "template",
    "boilerplate",
    "backend",
    "api",
    "rest",
    "restful",
    "typebox",
    "kysely",
    "sqlite"
  ],
  "author": "Pony",
  "license": "MIT",
  "dependencies": {
    "@fastify/autoload": "^6.0.0",
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.2.0",
    "@fastify/env": "^5.0.3",
    "@fastify/helmet": "^13.0.2",
    "@fastify/jwt": "^10.0.0",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/sensible": "^6.0.4",
    "@fastify/type-provider-typebox": "^6.1.0",
    "@fastify/under-pressure": "^9.0.3",
    "@sinclair/typebox": "^0.34.48",
    "better-sqlite3": "^12.6.2",
    "close-with-grace": "^2.5.0",
    "fastify": "^5.7.4",
    "fastify-favicon": "^5.0.0",
    "fastify-ip": "^2.0.0",
    "fastify-plugin": "^5.1.0",
    "kysely": "^0.28.11",
    "neverthrow": "^8.2.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "22.13.14",
    "c8": "^11.0.0",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "fastify-tsconfig": "^3.0.0",
    "glob": "^13.0.6",
    "kysely-codegen": "^0.20.0",
    "neostandard": "^0.13.0",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.8.1",
    "prettier-plugin-organize-imports": "^4.3.0",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3"
  }
}
